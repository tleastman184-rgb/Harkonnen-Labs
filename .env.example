# Harkonnen Labs — environment variables
#
# Copy to .env and fill in values for your setup.
# Never commit .env to git.
#
# Which setup file to load from setups/<name>.toml
# Omit or leave blank to use root harkonnen.toml (home-linux default)
HARKONNEN_SETUP=

# ── AI Providers ──────────────────────────────────────────────────────────────

# Anthropic — required for all setups
ANTHROPIC_API_KEY=sk-ant-...

# Google Gemini — home-linux only
GEMINI_API_KEY=

# OpenAI / Codex — home-linux only
OPENAI_API_KEY=

# ── MCP Server Keys ───────────────────────────────────────────────────────────

# GitHub MCP server (fetch_docs, github_read tool aliases)
GITHUB_TOKEN=ghp_...

# Brave Search MCP server (web_search tool alias)
# Free tier: 2000 queries/month — https://brave.com/search/api
BRAVE_API_KEY=

# ── AnythingLLM (home-linux only, requires Docker) ────────────────────────────
# Set by bootstrap-local-stack.sh — override here if needed
# ANYTHINGLLM_HOST_PORT=3001

# ── Logging ───────────────────────────────────────────────────────────────────
# RUST_LOG=info           # info | debug | trace
