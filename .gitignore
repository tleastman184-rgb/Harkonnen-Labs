target/
target-host/
.env
.claude/settings.local.json

# Python bytecode
__pycache__/
*.pyc
*.pyo

# SQLite state — regenerated at runtime
*.db
*.db-shm
*.db-wal

# Generated indexes and caches — rebuilt by `harkonnen memory init`
factory/memory/index.json
**/project-memory/index.json
factory/coordination/*.json
factory/coordination/assignments.md
factory/state/*.json

# Factory runtime directories — not source
factory/logs/
factory/artifacts/
factory/workspaces/
products/

# Clone-local setup files — generated per machine, not portable source
setups/discovered-*.toml
setups/machines/*.toml

# fastembed model cache — downloaded on first run, never committed
.fastembed_cache/

# Hugging Face model cache — lives at ~/.cache/huggingface/hub/ outside the repo
# Listed here as documentation; not tracked by git.

# Local benchmark and evaluation datasets — large BYO files kept out of git
development_datasets/
