{
  "mcpServers": {
    "memory": {
      "command": "flatpak-spawn",
      "args": ["--host", "npx", "-y", "@modelcontextprotocol/server-memory"]
    },
    "filesystem": {
      "command": "flatpak-spawn",
      "args": [
        "--host", "npx", "-y", "@modelcontextprotocol/server-filesystem",
        "./products", "./factory/workspaces", "./factory/artifacts", "./factory/memory"
      ]
    },
    "sqlite": {
      "command": "flatpak-spawn",
      "args": ["--host", "npx", "-y", "@modelcontextprotocol/server-sqlite", "./factory/state.db"]
    }
  }
}
